{
  "name": "@w3docs/ui",
  "version": "0.3.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react,react-dom --out-dir dist && cp src/styles/globals.css dist/globals.css",
    "lint": "eslint",
    "dev": "tsup src/index.ts --watch",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "clean": "rm -rf .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "pushout": "npm publish",
    "pushout-inc": "npm version patch --no-git-tag-version && pnpm pushout"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connectkit": "^1.9.2",
    "hugeicons-proxy": "^1.0.10",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "2.x",
    "wagmi": "^3.6.15",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@turbo/gen": "^2.8.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@w3docs/eslint-config": "workspace:*",
    "@w3docs/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/globals.css",
    "./styles/globals.css": "./dist/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
