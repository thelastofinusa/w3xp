{
  "name": "w3docs",
  "description": "Document smart contracts with ease",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "w3docs": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && chmod +x dist/index.js",
    "start:cli": "pnpm build && tsx src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@w3docs/core": "workspace:*",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "kleur": "^4.1.5",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@w3docs/tsconfig": "workspace:*",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0"
  }
}
